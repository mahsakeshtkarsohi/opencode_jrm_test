# Required environment variables for JRM Media Advisor.
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Databricks workspace URL (e.g. https://adb-<id>.azuredatabricks.net)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# Your Personal Access Token (PAT).
# Generate one at: User Settings → Developer → Access tokens → Generate new token
# The deployed app reads this from the jrm-advisor secret scope (key: databricks_token).
# No service principal is required — the app runs under your identity.
DATABRICKS_TOKEN=your-personal-access-token

# Genie Space ID for in-store campaign data queries
GENIE_SPACE_ID=your-genie-space-id

# Full invocation URL for the Knowledge Base (KA) Model Serving endpoint.
# Format: https://<DATABRICKS_HOST>/serving-endpoints/<endpoint-name>/invocations
KB_ENDPOINT_URL=https://adb-8342392658526315.15.azuredatabricks.net/serving-endpoints/ka-c3f1fbaf-endpoint/invocations

# SQL Warehouse ID for the campaign name resolver (search_campaigns UC function)
DATABRICKS_SQL_WAREHOUSE_ID=your-sql-warehouse-id

# Score threshold for campaign name resolution (0–1, default 0.7)
CAMPAIGN_RESOLVER_THRESHOLD=0.7

# Ambiguity gap — if top-2 scores differ by less than this, ask for clarification (default 0.05)
CAMPAIGN_RESOLVER_AMBIGUITY_GAP=0.05

# Full invocation URL for the foundation model endpoint used by the answer composer.
# Format: https://<DATABRICKS_HOST>/serving-endpoints/<endpoint-name>/invocations
# Example: https://adb-8342392658526315.15.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-6/invocations
COMPOSER_ENDPOINT=https://adb-8342392658526315.15.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-6/invocations

# MLflow experiment path for GenAI evaluation runs
MLFLOW_EXPERIMENT_NAME=/Shared/jrm-advisor-eval
